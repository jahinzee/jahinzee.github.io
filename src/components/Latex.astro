---
// based off code from: https://danidiaztech.com/create-astro-latex-component/

import katex from 'katex';

interface Props {
    formula?: string;
}

const { formula } = Astro.props
const source = await Astro.slots.render('default')
const displayedTex = katex.renderToString(source, {throwOnError: false})

---
<style>
    span.base {
        display: none;
    }
</style>

<span class="katex-html" set:html={displayedTex} />

