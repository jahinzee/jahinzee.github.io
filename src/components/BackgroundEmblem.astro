---
import type { ImageMetadata } from 'astro'
import Picture from 'astro/components/Picture.astro'
interface Props {
    emblem: string
}

const { emblem } = Astro.props

const emblemPath = `/src/assets/emblems/${emblem}.svg`
const emblems = import.meta.glob<{ default: ImageMetadata }>("/src/assets/emblems/*.svg");
const thisEmblem = emblems[emblemPath];

if (!thisEmblem) throw new Error(`Cannot find emblem!`);
---
<style>
    div.background-emblem {
        position: fixed;
        width: inherit;
        opacity: 5%;
        bottom: 0;
        right: 0;
        z-index: -1;
        pointer-events: none;
        user-select: none;
        filter: grayscale(50%);
    }

    @media only screen and (max-width: 960px) {
        div.background-emblem {
            width: 100%;
            bottom: 0;
            right: 0;
        }
    }

    img {
        width: 35em;
        height: auto;
    }
</style>
<div class="background-emblem">
    <Picture src={thisEmblem()} alt="image"/>
</div>