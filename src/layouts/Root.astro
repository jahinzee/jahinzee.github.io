---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BackgroundEmblem from "@components/BackgroundEmblem.astro";
import "@fontsource-variable/noto-sans";
import "@fontsource-variable/noto-sans-mono";

interface Props {
    title: string;
    no_h1: boolean;
    emblem?: string;
}

const { title, no_h1, emblem } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="jahinzee" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} - jahinzee</title>
    </head>
    <style is:global>
        :root {
            --main-bg: white;
            --main-fg: black;
            --accent: #694c9a;
            font-family: "Noto Sans Variable", sans-serif;
        }

        ::selection {
            background-color: color-mix(in srgb, var(--accent) 50%, white 50%);
        }

        tt,
        pre {
            font-size: larger;
            font-family: "Noto Sans Mono Variable", monospace;
        }

        body {
            display: flex;
            flex-flow: column nowrap;
            margin-left: auto;
            margin-right: auto;
            margin-top: 0;
            width: 70%;
            line-height: 1.5em;
        }

        @media only screen and (max-width: 960px) {
            body {
                width: 100%;
            }
        }

        a,
        details summary {
            text-decoration: none;
            color: var(--accent);
        }

        a:hover,
        details summary:hover {
            text-decoration: underline;
            cursor: pointer;
        }

        /* details {
            padding: 1em;
            padding-top: 0.75em;
            padding-bottom: 0.75em;
            border: 1px solid black;
            border-radius: 0.25em;
        } */

        details summary {
            cursor: pointer;
            list-style: none;
            font-weight: 550;
        }

        details[open] summary {
            padding-bottom: 0.5em;
            opacity: 75%;
        }

        details summary:before {
            content: "» ";
            padding-right: 0.1em;
        }

        h1 {
            font-size: x-large;
            margin-top: 0em;
            margin-bottom: 1.2em;
            font-weight: 600;
        }

        h2 {
            font-size: larger;
            font-weight: 550;
            width: 100%;
            /* background-color: red; */
            border-bottom: 0.05em solid lightgray;
            padding-bottom: 0.3em;
            margin-top: 1.5em;
            line-height: 1.5em;
        }

        article h3 {
            font-size: 1.1em;
            font-weight: 575;
            /* padding-bottom: 0.3em; */
            /* margin-top: 1.5em; */
            line-height: 1.5em;
        }

        main {
            background-color: var(--main-bg);
            padding: 1em 1em 2.5em 2.5em;
            flex-shrink: 0;
        }

        th,
        td {
            border-bottom: 0.1em solid rgba(0, 0, 0, 0.25);
            text-align: left;
            padding: 0.35em;
            padding-left: 0.5em;
            padding-right: 1.5em;
        }

        td:hover {
            background-color: rgba(0, 0, 0, 0.05);
        }

        th {
            border-bottom: 0.15em solid var(--main-fg);
        }

        table {
            border-collapse: collapse;
        }

        span.footnote-ref {
            font-size: smaller;
        }

        img {
            max-width: 100%;
            width: 50em;
            height: auto;
            display: block;
            margin-left: auto;
            margin-right: auto;
            padding-top: 1.5em;
            padding-bottom: 1.5em;
        }

        main {
            background: none;
        }

        blockquote {
            margin-left: 1.25em;
        }
    </style>

    <link
        rel="alternate"
        type="application/rss+xml"
        title="Your Site's Title"
        href={new URL("rss.xml", Astro.site)}
    />

    <body>
        <Fragment>
            {emblem !== undefined ? <BackgroundEmblem emblem={emblem} /> : null}
        </Fragment>

        <Header />
        <main>
            <Fragment>
                {no_h1 ? null : <h1 class="main-head">{title}</h1>}
            </Fragment>
            <slot />
        </main>
        <Footer />
    </body>
</html>
